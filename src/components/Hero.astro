---
import type { HeroProps } from "@types";
type Props = HeroProps;

const {
  name,
  specialty,
  headline,
  summary,
  email,
  location,
  availability,
  resume,
} = Astro.props;
---

<section class="py-20 md:py-28" id="hero">
  <div
    class="mb-8 flex flex-wrap items-center gap-3 text-xs font-semibold tracking-[0.16em] uppercase"
  >
    <span
      class="inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-2 text-emerald-300"
    >
      <span class="h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"
      ></span>
      {availability}
    </span>
    <span class="text-neutral">{location}</span>
  </div>

  <p class="mb-4 font-serif text-xl font-semibold text-primary">
    {name} · {specialty}
  </p>
  <h1
    class="max-w-4xl font-serif text-5xl font-bold tracking-tightest text-white sm:text-6xl md:text-7xl"
  >
    {headline}
  </h1>
  <p class="mt-8 max-w-3xl text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <div class="mt-10 flex flex-wrap gap-4">
    <a
      class="rounded-full bg-primary px-7 py-4 text-sm font-semibold text-white transition hover:bg-blue-500 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
      href="#projects">View featured work</a
    >
    <a
      class="rounded-full border border-white/20 px-7 py-4 text-sm font-semibold text-white transition hover:border-white/40 hover:bg-white/5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
      href={resume}
      target="_blank"
      rel="noopener noreferrer">View résumé</a
    >
    <a
      class="rounded-full px-7 py-4 text-sm font-semibold text-neutral transition hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
      href={`mailto:${email}`}>Contact me</a
    >
  </div>
</section>
